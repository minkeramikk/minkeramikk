# Copy to .env.local and fill in from the Supabase dashboard.
# NEVER commit .env.local (.gitignore already covers .env*).

# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (import scripts, route handlers). Never exposed to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase CLI (link, db push, gen types) — account-level token + db password
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=

# GitHub pushes from agent sessions (fine-grained PAT, Contents read/write)
GITHUB_TOKEN=

# Cloudflare Turnstile (F05). In dev/CI the documented test keys are used when
# unset (site key always passes; secret always passes). Set real keys in prod.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend (F05). When RESEND_API_KEY is unset the email transport is a no-op
# (dev/CI never sends). Verify the sender domain before production.
RESEND_API_KEY=
ORDER_EMAIL_FROM=
ORDER_NOTIFY_EMAIL=

# Back-office admin seed (F06). The ONLY way to provision the single admin
# (no public signup). `npm run seed:admin` creates/updates this user via the
# service-role key. Choose your own password; it is never committed or logged.
# The e2e login test reads the same two vars (skips if unset).
ADMIN_EMAIL=
ADMIN_PASSWORD=
