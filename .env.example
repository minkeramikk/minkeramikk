# Copia questo file in .env.local e riempi i valori dal dashboard Supabase
# (Project Settings → API). MAI committare .env.local (.gitignore copre già .env*).

# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://rqhsbpwvzesvqwdonirf.supabase.co

# Project Settings → API → anon public key (safe per il browser, protetta da RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=dd

# Project Settings → API → service_role key (SOLO server: import script, route handlers,
# seeding/cleanup degli e2e). MAI nel client.
SUPABASE_SERVICE_ROLE_KEY=role

SUPABASE_DB_PASSWORD=dd
SUPABASE_ACCESS_TOKEN=dd

# Email (Resend). In dev/e2e lasciare RESEND_API_KEY VUOTA → transport no-op (nessun
# invio). `make test-email` la attiva al volo per un solo ordine verso la casella di test.
# In produzione: chiave reale + sender verificato (fail-closed, ADR 0013).
RESEND_API_KEY=
ORDER_EMAIL_FROM=Min Keramikk <onboarding@resend.dev>
ORDER_NOTIFY_EMAIL=dangeli88.daniele@gmail.com

# Back-office (gli e2e admin si auto-skippano se mancano).
ADMIN_EMAIL=admin@minkeramikk.no
ADMIN_PASSWORD=ddd

# Difesa in profondità: SOLO queste email (CSV) contano come admin, anche con
# una sessione Supabase valida. Se VUOTA → nessuna restrizione (comportamento
# pre-hardening) così un env mancante non ti chiude fuori. In produzione:
# ADMIN_ALLOWLIST=tech@minkeramikk.no  (impostala su Vercel per attivare la guardia)
ADMIN_ALLOWLIST=

# Keep-alive cron (Vercel). Impedisce al progetto Supabase Free di andare in pausa
# dopo ~7 giorni senza attività DB. Vercel invia questo valore come header
# `Authorization: Bearer` sulle invocazioni cron di /api/keepalive → il route
# rifiuta con 401 qualsiasi altra chiamata. Genera con: openssl rand -hex 32.
# Impostarla su Vercel (Production); in locale può restare vuota (route bloccata).
CRON_SECRET=

# On-demand: per invocare la keep-alive di PRODUZIONE da locale
# (`npm run keepalive:prod`), metti qui lo STESSO valore del CRON_SECRET di
# produzione. KEEPALIVE_URL è opzionale (default: NEXT_PUBLIC_SITE_URL o
# https://minkeramikk.no, + /api/keepalive).
CRON_ACCESS=
KEEPALIVE_URL=

# Anti-bot (Cloudflare Turnstile). VUOTE in dev/e2e → il widget emette il token di
# test always-pass e il server usa il secret always-pass (flusso ordine testabile
# headless). In produzione: chiavi reali. NB: NEXT_PUBLIC_* è inlinata a BUILD-time;
# `make build` per gli e2e forza comunque la site key vuota.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Frakt med forsikring (R3-B4): soglia in NOK interi sopra la quale la spedizione
# assicurata è inclusa. Vuota/non valida → fallback 1000. NB: NEXT_PUBLIC_* è
# inlinata a BUILD-time (cambiarla richiede un rebuild).
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD_NOK=1000
